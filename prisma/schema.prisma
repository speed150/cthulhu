generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  username   String      @unique
  password   String
  createdAt  DateTime    @default(now())
  characters Character[]
}

model Character {
  id              String   @id @default(cuid())
  name            String
  occupation      String?
  age             Int?
  residence       String?
  birthplace      String?
  userId          String
  HP              Int
  maxHP           Int
  mjWound         Boolean
  MP              Int
  maxMP           Int
  luck            Int
  sanity          Int
  characteristics Json
  baseSkills      Json
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}
